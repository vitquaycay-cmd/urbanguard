generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model ForumUser {
  id           String  @id @default(cuid())
  fullName     String
  email        String  @unique
  passwordHash String
  avatarUrl    String?
  role         String  @default("user")
  status       String  @default("active")
  city         String?
  district     String?

  posts    ForumPost[]
  likes    ForumPostLike[]
  comments ForumComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ForumCategory {
  id    String  @id @default(cuid())
  name  String
  slug  String  @unique
  icon  String?
  color String?

  posts ForumPost[]

  createdAt DateTime @default(now())
}

model ForumPost {
  id            String  @id @default(cuid())
  userId        String
  categoryId    String
  title         String
  content       String  @db.Text
  locationText  String?
  city          String?
  district      String?
  severity      String  @default("medium")
  status        String  @default("approved")
  viewsCount    Int     @default(0)
  likesCount    Int     @default(0)
  commentsCount Int     @default(0)
  sharesCount   Int     @default(0)
  isFeatured    Boolean @default(false)

  author   ForumUser        @relation(fields: [userId], references: [id])
  category ForumCategory    @relation(fields: [categoryId], references: [id])
  media    ForumPostMedia[]
  likes    ForumPostLike[]
  comments ForumComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([categoryId])
}

model ForumPostMedia {
  id       String @id @default(cuid())
  postId   String
  url      String
  type     String
  fileName String
  mimeType String
  size     Int

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([postId])
}

model ForumPostLike {
  id     String @id @default(cuid())
  postId String
  userId String

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user ForumUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model ForumComment {
  id      String @id @default(cuid())
  postId  String
  userId  String
  content String @db.Text

  post ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user ForumUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([userId])
}
