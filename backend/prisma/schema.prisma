generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// Người dùng hệ thống — 1 User có nhiều Report (báo cáo do chính user tạo).
model User {
  id              Int            @id @default(autoincrement())
  email           String         @unique
  password        String
  reputationScore Int            @default(0) @map("reputation_score")
  role            Role           @default(USER)
  notifications   Notification[]
  reports         Report[]
  votes           Vote[]

  @@map("users")
}

model Report {
  id            Int            @id @default(autoincrement())
  title         String
  description   String         @db.Text
  latitude      Float
  longitude     Float
  imageUrl      String?        @map("image_url")
  status        ReportStatus   @default(PENDING)
  trustScore    Float          @default(0) @map("trust_score")
  createdAt     DateTime       @default(now()) @map("created_at")
  userId        Int            @map("user_id")
  /// Kết quả thô từ service AI (FastAPI /predict), JSON.
  aiSummary     Json?          @map("ai_summary")
  /// Nhãn AI (ví dụ danh sách class_name) — JSON array string.
  aiLabels      Json?          @map("ai_labels")
  notifications Notification[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes         Vote[]

  @@index([userId])
  @@index([latitude, longitude])
  @@map("reports")
}

/// Một user chỉ một lần vote cho một report (dùng để tính Trust Score).
model Vote {
  id       Int      @id @default(autoincrement())
  userId   Int      @map("user_id")
  reportId Int      @map("report_id")
  type     VoteType
  report   Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reportId])
  @@index([reportId], map: "votes_report_id_fkey")
  @@map("votes")
}

/// Thông báo / cảnh báo khu vực cho user (đồng bộ module notifications).
model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int              @map("user_id")
  title     String
  body      String           @db.Text
  type      NotificationType @default(REPORT_UPDATE)
  reportId  Int?             @map("report_id")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")
  report    Report?          @relation(fields: [reportId], references: [id])
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([reportId])
  @@map("notifications")
}

enum Role {
  ADMIN
  USER
}

enum ReportStatus {
  PENDING
  /// Đã admin duyệt — hiển thị trên bản đồ công khai.
  VALIDATED
  /// Giữ để tương thích dữ liệu cũ (trước khi dùng VALIDATED).
  VERIFIED
  RESOLVED
  REJECTED
}

enum VoteType {
  UPVOTE
  DOWNVOTE
}

enum NotificationType {
  AREA_ALERT
  REPORT_UPDATE
  SYSTEM
}
